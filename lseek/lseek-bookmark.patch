diff --git a/fs/read_write.c b/fs/read_write.c
index 833bae068..e07b590b1 100644
--- a/fs/read_write.c
+++ b/fs/read_write.c
@@ -5,6 +5,9 @@
  *  Copyright (C) 1991, 1992  Linus Torvalds
  */
 
+#include <asm-generic/errno-base.h>
+#include <linux/fs.h>
+#include <linux/list.h>
 #include <linux/slab.h>
 #include <linux/stat.h>
 #include <linux/sched/xacct.h>
@@ -384,6 +387,36 @@ EXPORT_SYMBOL(default_llseek);
 
 loff_t vfs_llseek(struct file *file, loff_t offset, int whence)
 {
+	if (whence & SEEK_PUSH) {
+		struct bookmark *new;
+		new = kzalloc(sizeof(*new), GFP_KERNEL);
+		if (!new)
+			return -ENOMEM;
+
+		new->f_pos = file->f_pos;
+
+		list_add_tail(&new->node, &file->bookmark_head.node);
+	}
+	if (whence & SEEK_POP) {
+		if (list_empty(&file->bookmark_head.node))
+			return -EINVAL;
+
+		struct bookmark *last = list_last_entry(&file->bookmark_head.node, struct bookmark, node);
+		list_del(&last->node);
+		kfree(last);
+	}
+
+	whence &= ~(SEEK_PUSH | SEEK_POP);
+
+	if (whence == SEEK_BOOKMARK) {
+		if (list_empty(&file->bookmark_head.node))
+			return -EINVAL;
+
+		struct bookmark *last = list_last_entry(&file->bookmark_head.node, struct bookmark, node);
+		offset += last->f_pos;
+		whence = SEEK_SET;
+	}
+
 	if (!(file->f_mode & FMODE_LSEEK))
 		return -ESPIPE;
 	return file->f_op->llseek(file, offset, whence);
@@ -398,7 +431,7 @@ static off_t ksys_lseek(unsigned int fd, off_t offset, unsigned int whence)
 		return -EBADF;
 
 	retval = -EINVAL;
-	if (whence <= SEEK_MAX) {
+	if ((whence & ~(SEEK_PUSH | SEEK_POP)) <= SEEK_MAX) {
 		loff_t res = vfs_llseek(fd_file(f), offset, whence);
 		retval = res;
 		if (res != (loff_t)retval)
@@ -432,7 +465,7 @@ SYSCALL_DEFINE5(llseek, unsigned int, fd, unsigned long, offset_high,
 	if (fd_empty(f))
 		return -EBADF;
 
-	if (whence > SEEK_MAX)
+	if ((whence & ~(SEEK_PUSH | SEEK_POP)) > SEEK_MAX)
 		return -EINVAL;
 
 	offset = vfs_llseek(fd_file(f), ((loff_t) offset_high << 32) | offset_low,
